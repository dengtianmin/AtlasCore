APP_CONFIG_PATH=/home/Project/AtlasCore/config/app.example.yaml
APP_NAME=AtlasCore API
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO
SQLITE_PATH=/home/Project/AtlasCore/data/atlascore.db
CSV_EXPORT_DIR=/home/Project/AtlasCore/data/exports
DOCUMENT_LOCAL_STORAGE_DIR=/home/Project/AtlasCore/data/uploads
GRAPH_ENABLED=true
GRAPH_DEFAULT_LIMIT=100
GRAPH_MAX_NEIGHBORS=200
GRAPH_RELOAD_ON_START=true
GRAPH_EXPORT_DIR=/home/Project/AtlasCore/data/graph_exports
GRAPH_IMPORT_DIR=/home/Project/AtlasCore/data/graph_imports
GRAPH_INSTANCE_LOCAL_PATH=/home/Project/AtlasCore/data/atlascore_graph.db
GRAPH_INSTANCE_ID=atlascore-instance-local
GRAPH_DB_VERSION=atlascore-graph-v1
GRAPH_SNAPSHOT_PATH=/home/Project/AtlasCore/data/atlascore_graph.db

# Non-secret Key Vault controls:
KEY_VAULT_ENABLED=false
# KEY_VAULT_URL=https://atlascore-kv.vault.azure.net
# AZURE_KEY_VAULT_URL=https://atlascore-kv.vault.azure.net
KEY_VAULT_USE_MANAGED_IDENTITY=false
KEY_VAULT_TIMEOUT_SECONDS=5

# Secret values for local development:
INITIAL_ADMIN_PASSWORD=StrongPass123!
JWT_SECRET=local-dev-secret
# ADMIN_AUTH_SECRET=
# ADMIN_PASSWORD_HASH=
# DIFY_API_KEY=
# DIFY_BASE_URL=https://api.dify.ai/v1
# DIFY_TIMEOUT_SECONDS=15
# DIFY_TEXT_INPUT_VARIABLE=query
# DIFY_RESPONSE_MODE=streaming

# Secret names for Azure Key Vault SDK mode:
# INITIAL_ADMIN_PASSWORD_SECRET_NAME=atlascore-initial-admin-password
# JWT_SECRET_NAME=atlascore-jwt-secret
# ADMIN_AUTH_SECRET_NAME=atlascore-admin-auth-secret
# ADMIN_PASSWORD_HASH_SECRET_NAME=atlascore-admin-password-hash
# DIFY_API_KEY_SECRET_NAME=atlascore-dify-api-key

# Reserved integrations; not required for the current SQLite-first runtime:
# NEO4J_URI=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j
# DIFY_API_BASE=

# Graph extraction LLM defaults:
GRAPH_EXTRACTION_MODEL_PROVIDER=openai-compatible
GRAPH_EXTRACTION_MODEL_NAME=gpt-4o-mini
GRAPH_EXTRACTION_MODEL_API_BASE_URL=https://api.openai.com/v1
# GRAPH_EXTRACTION_MODEL_API_KEY=
# GRAPH_EXTRACTION_MODEL_API_KEY_SECRET_NAME=atlascore-graph-extraction-model-api-key
GRAPH_EXTRACTION_MODEL_ENABLED=false
GRAPH_EXTRACTION_MODEL_THINKING_ENABLED=true
# GRAPH_EXTRACTION_PROMPT=
