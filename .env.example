APP_NAME=AtlasCore API
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# Required in production
JWT_SECRET=

# Optional in current stage, required when PostgreSQL is enabled
DATABASE_URL=
# Example (local): postgresql+psycopg://postgres:postgres@localhost:5432/atlascore

# Optional in current stage, required together when Neo4j is enabled
NEO4J_URI=
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Optional in current stage, required together when Dify integration is enabled
DIFY_BASE_URL=
DIFY_API_KEY=

# V1 placeholder storage path (for local/dev only)
DOCUMENT_LOCAL_STORAGE_DIR=./data/uploads
